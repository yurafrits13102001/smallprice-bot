BOT_TOKEN=
OPENAI_API_KEY=
PRODUCTS_PATH=data/products.xlsx
INDEX_PATH=data/faiss_index
SIMILARITY_THRESHOLD=0.75
APIFY_TOKEN=
# CLIP image-build scraping throughput. Lower concurrency = gentler on
# marketplaces that throttle bursts (AliExpress); raise only if no throttling.
CLIP_SCRAPE_CONCURRENCY=6
CLIP_SCRAPE_TIMEOUT=15.0
# Headless-browser image fallback (Playwright). Renders JS-only pages (1688,
# AliExpress) the static scrape can't. Runs on this host (no cost). Set =1 to
# enable. PLAYWRIGHT_PROXY is optional, for sites that block the server IP.
USE_PLAYWRIGHT=0
PLAYWRIGHT_CONCURRENCY=3
PLAYWRIGHT_PROXY=
